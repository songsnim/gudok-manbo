# Obsidian Vault 절대 경로 (예: C:\Users\User\Documents\MyVault)
VAULT_PATH=C:\Users\User\Documents\ObsidianVault

# Ollama 설정
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# OpenRouter (Discovery용, 무료 tier)
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free

# 요약 언어 (ko 또는 en)
SUMMARY_LANGUAGE=ko

# 하루 수집 할당량
DAILY_QUOTA=10
